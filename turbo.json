{
  "$schema": "https://turbo.build/schema.json",
  "globalPassThroughEnv": [
    "TURBO_API",
    "TURBO_REMOTE_ONLY",
    "TURBO_TEAM",
    "TURBO_TOKEN"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "test": {
      "dependsOn": ["build"]
    },
    "lint": {},
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "clean": {
      "cache": false
    }
  }
}
