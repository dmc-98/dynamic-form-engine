{
  "name": "@dmc--98/dfe-core",
  "version": "0.1.0",
  "description": "Configuration-driven dynamic form engine — types, DAG, conditions, validation, stepper",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0",
    "zod": "^3.22.0"
  },
  "keywords": ["form", "dynamic-form", "form-builder", "form-engine", "multi-step", "validation", "zod", "dag", "conditional-logic"],
  "repository": {
    "type": "git",
    "url": "https://github.com/snarjun98/dynamic-form-engine",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/snarjun98/dynamic-form-engine#readme",
  "bugs": "https://github.com/snarjun98/dynamic-form-engine/issues"
}
