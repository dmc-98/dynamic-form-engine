{
  "name": "@dmc-98/dfe-cli",
  "version": "0.1.0",
  "description": "CLI scaffolding tool for Dynamic Form Engine",
  "license": "MIT",
  "type": "module",
  "bin": {
    "dfe": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/pg": "^8.15.6",
    "typescript": "^5.4.0",
    "tsup": "^8.0.0",
    "vitest": "^1.6.0"
  },
  "files": ["dist", "templates", "README.md", "LICENSE"],
  "tsup": {
    "entry": ["src/index.ts"],
    "format": ["esm"],
    "dts": false,
    "clean": true,
    "banner": { "js": "#!/usr/bin/env node" }
  }
}
