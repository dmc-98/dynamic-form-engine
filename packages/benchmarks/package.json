{
  "name": "@dmc--98/dfe-benchmarks",
  "version": "0.0.0",
  "private": true,
  "description": "Reproducible performance benchmark harness for Dynamic Form Engine (PRD: Core Excellence). Engine-level today; DOM + competitor lanes (rjsf, Formily, survey-core) plug into the same scenario generator.",
  "type": "commonjs",
  "scripts": {
    "test": "vitest run",
    "bench:dom:build": "esbuild src/dom-entry.tsx --bundle --outfile=dom-dist/bundle.js --alias:@dmc--98/dfe-react=../react/src/index.ts --alias:@dmc--98/dfe-core=../core/src/index.ts --jsx=automatic --define:process.env.NODE_ENV='\"production\"' --minify",
    "bench:engine": "DFE_BENCH=1 vitest run test/engine-bench.test.ts"
  },
  "dependencies": {
    "@dmc--98/dfe-core": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
