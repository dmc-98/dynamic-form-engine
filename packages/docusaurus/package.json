{
  "name": "@dmc-98/dfe-docusaurus",
  "version": "0.1.0",
  "description": "Docusaurus plugin helpers for Dynamic Form Engine",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./DfeFormPage": {
      "types": "./dist/DfeFormPage.d.ts",
      "import": "./dist/DfeFormPage.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@dmc-98/dfe-core": "workspace:*",
    "@dmc-98/dfe-react": "workspace:*"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "typescript": "^5.4.0",
    "tsup": "^8.0.0",
    "vitest": "^1.6.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "examples"
  ],
  "tsup": {
    "entry": [
      "src/index.ts",
      "src/DfeFormPage.tsx"
    ],
    "format": [
      "esm"
    ],
    "dts": true,
    "clean": true,
    "sourcemap": true,
    "external": [
      "react",
      "react-dom"
    ]
  }
}
