{
  "name": "@dmc-98/dfe-prisma",
  "version": "0.1.0",
  "description": "Prisma database adapter for Dynamic Form Engine",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./schema": {
      "import": "./schema/schema.prisma"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@dmc-98/dfe-core": "workspace:*",
    "@dmc-98/dfe-server": "workspace:*"
  },
  "peerDependencies": {
    "@prisma/client": "^5.0.0 || ^6.0.0"
  },
  "devDependencies": {
    "@prisma/client": "^6.0.0",
    "typescript": "^5.4.0",
    "tsup": "^8.0.0",
    "vitest": "^1.6.0"
  },
  "files": [
    "dist",
    "schema",
    "README.md",
    "LICENSE"
  ],
  "tsup": {
    "entry": [
      "src/index.ts"
    ],
    "format": [
      "esm",
      "cjs"
    ],
    "dts": true,
    "clean": true,
    "sourcemap": true
  }
}
