---
interface Props {
  title: string
  description: string
  /** OG/Twitter card image, resolved against the site origin. Default: /og.png */
  ogImage?: string
}
const { title, description, ogImage = '/og.png' } = Astro.props
const canonical = new URL(Astro.url.pathname, Astro.site)
const ogImageUrl = new URL(ogImage, Astro.site)
const siteName = 'Dynamic Form Engine'
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical.href} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical.href} />
    <meta property="og:image" content={ogImageUrl.href} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Dynamic Form Engine — one config for your whole form stack" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl.href} />

    <!-- JSON-LD: SoftwareApplication -->
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'SoftwareApplication',
      name: siteName,
      applicationCategory: 'DeveloperApplication',
      operatingSystem: 'Any',
      offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
      description,
      url: canonical.href,
    })} />

    <meta name="theme-color" content="#0f766e" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#020617" media="(prefers-color-scheme: dark)" />

    <!-- No-flash theme init: apply the saved theme before first paint. -->
    <script is:inline>
      (() => {
        try {
          const t = localStorage.getItem('dfe-theme')
          if (t === 'light' || t === 'dark') document.documentElement.dataset.theme = t
        } catch { /* ignore */ }
      })()
    </script>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=IBM+Plex+Sans:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <slot name="head" />
  </head>
  <body data-dfe-theme>
    <slot />
  </body>
</html>

<style is:global>
  /* ── Mirrored DFE design tokens (Graphite & Teal) ───────────────────────────
   * Vendored copy of @dmc--98/dfe-tokens for this standalone site. Defined on
   * :root (everything inherits, incl. body[data-dfe-theme] and DFE islands).
   * Theme model: LIGHT by default → DARK when the OS prefers dark (unless the
   * user forced light) → DARK/LIGHT when explicitly chosen via html[data-theme].
   * Keep in sync with packages/tokens/tokens.css. */
  :root {
    /* primitives */
    --dfe-teal-300: #5eead4; --dfe-teal-400: #2dd4bf; --dfe-teal-500: #14b8a6;
    --dfe-teal-600: #0d9488; --dfe-teal-700: #0f766e;
    --dfe-slate-0: #ffffff; --dfe-slate-50: #f8fafc; --dfe-slate-100: #f1f5f9;
    --dfe-slate-400: #94a3b8; --dfe-slate-700: #334155; --dfe-slate-900: #0f172a; --dfe-slate-950: #020617;

    /* theme-independent scales */
    --dfe-r-sm:.375rem; --dfe-r-md:.5rem; --dfe-r-lg:.75rem; --dfe-r-xl:1rem; --dfe-r-2xl:1.5rem; --dfe-pill:999px;
    --dfe-ease: cubic-bezier(.2,0,0,1); --dfe-ease-spring: cubic-bezier(.34,1.56,.64,1);
    --dfe-gradient-sheen: linear-gradient(180deg, rgba(255,255,255,.18), transparent);
    --dfe-font-sans: "IBM Plex Sans", "Avenir Next", system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
    --dfe-font-mono: "IBM Plex Mono", ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;

    /* LIGHT semantic layer (default) */
    --dfe-color-canvas: #f8fafc; --dfe-color-surface: #ffffff; --dfe-color-surface-muted: #f1f5f9;
    --dfe-color-surface-sunken: #eef2f6;
    --dfe-color-border: #e2e8f0; --dfe-color-border-strong: #cbd5e1;
    --dfe-color-text: #0f172a; --dfe-color-text-muted: #475569; --dfe-color-text-subtle: #64748b;
    --dfe-color-primary: #0f766e; --dfe-color-primary-hover: #115e59;
    --dfe-color-primary-subtle: #f0fdfa; --dfe-color-primary-border: #99f6e4;
    --dfe-color-success: #15803d; --dfe-color-warning: #b45309; --dfe-color-danger: #b91c1c;
    --dfe-focus: rgba(13,148,136,.28);
    --dfe-glass: color-mix(in srgb, #ffffff 78%, transparent);
    --dfe-gradient-brand: linear-gradient(135deg, #14b8a6, #0f766e);
    --dfe-gradient-hero:
      radial-gradient(120% 120% at 0% 0%, #f0fdfa 0%, transparent 45%),
      radial-gradient(120% 120% at 100% 0%, #eef6ff 0%, transparent 40%),
      linear-gradient(180deg, #ffffff, #f8fafc);
    --dfe-shadow-sm: 0 1px 3px rgba(15,23,42,.08), 0 1px 2px rgba(15,23,42,.04);
    --dfe-shadow-md: 0 4px 12px rgba(15,23,42,.08), 0 2px 4px rgba(15,23,42,.04);
    --dfe-shadow-lg: 0 12px 28px rgba(15,23,42,.12), 0 4px 8px rgba(15,23,42,.06);
    --dfe-shadow-xl: 0 24px 56px rgba(15,23,42,.16);

    /* local aliases the markup uses → resolve dynamically from the tokens above */
    --bg: var(--dfe-color-canvas); --panel: var(--dfe-color-surface); --text: var(--dfe-color-text);
    --muted: var(--dfe-color-text-muted); --border: var(--dfe-color-border);
    --brand: var(--dfe-color-primary); --brand2: var(--dfe-teal-600); --code-bg: var(--dfe-color-surface-sunken);
    --radius: 12px; --max: 1080px;
  }

  /* DARK values — shared by "OS dark (not forced light)" and "explicitly dark". */
  :root[data-theme="dark"] {
    --dfe-color-canvas: #020617; --dfe-color-surface: #0f172a; --dfe-color-surface-muted: #1e293b;
    --dfe-color-surface-sunken: #0b1120;
    --dfe-color-border: #334155; --dfe-color-border-strong: #475569;
    --dfe-color-text: #f1f5f9; --dfe-color-text-muted: #94a3b8; --dfe-color-text-subtle: #64748b;
    --dfe-color-primary: #2dd4bf; --dfe-color-primary-hover: #5eead4;
    --dfe-color-primary-subtle: rgba(20,184,166,.12); --dfe-color-primary-border: rgba(45,212,191,.35);
    --dfe-color-success: #4ade80; --dfe-color-warning: #fbbf24; --dfe-color-danger: #f87171;
    --dfe-focus: rgba(45,212,191,.35);
    --dfe-glass: color-mix(in srgb, #0f172a 66%, transparent);
    --dfe-gradient-brand: linear-gradient(135deg, #2dd4bf, #0d9488);
    --dfe-gradient-hero:
      radial-gradient(120% 120% at 0% 0%, rgba(20,184,166,0.18) 0%, transparent 45%),
      radial-gradient(120% 120% at 100% 0%, rgba(45,212,191,0.12) 0%, transparent 40%),
      linear-gradient(180deg, #020617, #0b1120);
    --dfe-shadow-sm: 0 1px 3px rgba(0,0,0,.5);
    --dfe-shadow-md: 0 8px 20px rgba(0,0,0,.5);
    --dfe-shadow-lg: 0 16px 36px rgba(0,0,0,.6);
    --dfe-shadow-xl: 0 28px 60px rgba(0,0,0,.7);
    --brand2: var(--dfe-teal-300);
  }
  @media (prefers-color-scheme: dark) {
    :root:not([data-theme="light"]) {
      --dfe-color-canvas: #020617; --dfe-color-surface: #0f172a; --dfe-color-surface-muted: #1e293b;
      --dfe-color-surface-sunken: #0b1120;
      --dfe-color-border: #334155; --dfe-color-border-strong: #475569;
      --dfe-color-text: #f1f5f9; --dfe-color-text-muted: #94a3b8; --dfe-color-text-subtle: #64748b;
      --dfe-color-primary: #2dd4bf; --dfe-color-primary-hover: #5eead4;
      --dfe-color-primary-subtle: rgba(20,184,166,.12); --dfe-color-primary-border: rgba(45,212,191,.35);
      --dfe-color-success: #4ade80; --dfe-color-warning: #fbbf24; --dfe-color-danger: #f87171;
      --dfe-focus: rgba(45,212,191,.35);
      --dfe-glass: color-mix(in srgb, #0f172a 66%, transparent);
      --dfe-gradient-brand: linear-gradient(135deg, #2dd4bf, #0d9488);
      --dfe-gradient-hero:
        radial-gradient(120% 120% at 0% 0%, rgba(20,184,166,0.18) 0%, transparent 45%),
        radial-gradient(120% 120% at 100% 0%, rgba(45,212,191,0.12) 0%, transparent 40%),
        linear-gradient(180deg, #020617, #0b1120);
      --dfe-shadow-sm: 0 1px 3px rgba(0,0,0,.5);
      --dfe-shadow-md: 0 8px 20px rgba(0,0,0,.5);
      --dfe-shadow-lg: 0 16px 36px rgba(0,0,0,.6);
      --dfe-shadow-xl: 0 28px 60px rgba(0,0,0,.7);
      --brand2: var(--dfe-teal-300);
    }
  }

  * { box-sizing: border-box; }
  html { color-scheme: light dark; }
  body { margin: 0; font-family: var(--dfe-font-sans); background: var(--bg); color: var(--text); line-height: 1.55; -webkit-font-smoothing: antialiased; transition: background .3s var(--dfe-ease), color .3s var(--dfe-ease); }
  a { color: var(--brand); text-decoration: none; }
  a:hover { text-decoration: underline; }
  .wrap { max-width: var(--max); margin: 0 auto; padding: 0 24px; }
  @media (prefers-reduced-motion: reduce) {
    * { animation-duration: 0.001ms !important; transition-duration: 0.001ms !important; scroll-behavior: auto !important; }
  }
</style>
