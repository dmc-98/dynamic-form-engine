---
import { getEntry } from 'astro:content'
import Base from '../layouts/Base.astro'

// All copy comes from the content collection (editable via /admin).
const { data } = await getEntry('site', 'home')
const { hero, features, comparison, sponsorTiers, demoEmbedUrl, githubUrl, docsUrl, sponsorUrl, claudeCode } = data
---

<Base
  title="Dynamic Form Engine — Forms Are Workflows"
  description={hero.subtitle}
>
  <header class="nav">
    <div class="brand"><span class="dot"></span> Dynamic Form Engine</div>
    <nav class="links">
      <a href="#features">Features</a>
      <a href="#demo">Demo</a>
      <a href="#claude-code">Claude Code</a>
      <a href="#compare">Compare</a>
      <a href="#sponsor">Sponsor</a>
      <a href={githubUrl}>GitHub</a>
    </nav>
  </header>

  <main class="wrap">
    <section class="hero">
      <span class="eyebrow">{hero.eyebrow}</span>
      <h1>{hero.title}</h1>
      <p class="sub">{hero.subtitle}</p>
      <div class="cta">
        <a class="btn primary" href={hero.primaryCta.href}>{hero.primaryCta.label}</a>
        {hero.secondaryCtas.map((c) => <a class="btn ghost" href={c.href}>{c.label}</a>)}
      </div>
      <div class="codeblock">
        <pre><code>{`import { createFormEngine } from '@dmc--98/dfe-core'

const engine = createFormEngine(fields, existingData)
const patch  = engine.setFieldValue('role', 'admin') // only affected fields recompute
const { success, errors } = engine.validate()         // Zod schema, auto-generated`}</code></pre>
      </div>
    </section>

    <section id="features">
      <h2>Built for forms that behave like systems</h2>
      <p class="lede">Onboarding, applications, approvals, and internal tools — not just input screens.</p>
      <div class="grid">
        {features.map((f) => (
          <div class="card">
            <div class="ico">{f.icon}</div>
            <h3>{f.title}</h3>
            <p>{f.body}</p>
          </div>
        ))}
      </div>
    </section>

    <section id="demo">
      <h2>Try it in your browser</h2>
      <p class="lede">A live multi-step form. Set Account Type to “Business” and watch fields appear.</p>
      {demoEmbedUrl
        ? <iframe class="demo" src={demoEmbedUrl} title="Dynamic Form Engine live demo" loading="lazy" credentialless allow="cross-origin-isolated"></iframe>
        : <div class="demo placeholder">▶ Live demo / video goes here</div>}
      {demoEmbedUrl ? (
        <p class="demo-fallback">
          Embed not loading? <a href={demoEmbedUrl.replace('embed=1&', '').replace(/[?&]embed=1/, '')} target="_blank" rel="noopener">Open the demo in a new tab →</a>
        </p>
      ) : null}
    </section>

    {claudeCode ? (
      <section id="claude-code">
        <h2>{claudeCode.heading}</h2>
        <p class="lede">{claudeCode.body}</p>
        <div class="codeblock">
          <pre><code>{`${claudeCode.marketplaceCmd}\n${claudeCode.installCmd}`}</code></pre>
        </div>
        <p class="cc-cta">
          <a class="btn ghost" href={claudeCode.docsUrl}>Plugin docs</a>
        </p>
      </section>
    ) : null}

    <section id="compare">
      <h2>Where DFE fits</h2>
      <p class="lede">Between lightweight React form-state libraries and hosted form platforms.</p>
      <table class="compare">
        <thead><tr><th>Tool</th><th>Best at</th><th>Where DFE fits</th></tr></thead>
        <tbody>
          {comparison.map((r) => (
            <tr><td>{r.tool}</td><td>{r.bestAt}</td><td>{r.dfe}</td></tr>
          ))}
        </tbody>
      </table>
    </section>

    <section id="sponsor" class="sponsor">
      <h2>Sponsor Dynamic Form Engine</h2>
      <p class="lede">MIT-licensed and independently maintained. Sponsorship funds maintenance, security, docs, and releases.</p>
      <div class="tiers">
        {sponsorTiers.map((t) => (
          <div class="tier">
            <div class="name">{t.name}</div>
            <div class="amt">{t.amount}</div>
            <p>{t.perk}</p>
          </div>
        ))}
      </div>
      <p class="note">Recognition and access scale with tier. Influence over correctness, security, or the project's independence is never for sale.</p>
      <div class="cta"><a class="btn primary" href={sponsorUrl}>Become a sponsor</a></div>
    </section>
  </main>

  <footer>
    Dynamic Form Engine · MIT Licensed · <a href={githubUrl}>GitHub</a> · <a href={docsUrl}>Docs</a>
  </footer>
</Base>

<style>
  header.nav { display: flex; align-items: center; justify-content: space-between; padding: 20px 24px; max-width: var(--max); margin: 0 auto; }
  .brand { font-weight: 700; font-size: 18px; display: flex; align-items: center; gap: 10px; }
  .brand .dot { width: 14px; height: 14px; border-radius: 4px; background: linear-gradient(135deg, var(--brand), var(--brand2)); }
  nav.links a { color: var(--muted); margin-left: 22px; font-size: 14px; }
  nav.links a:hover { color: var(--text); }

  .hero { text-align: center; padding: 72px 0 56px; }
  .eyebrow { display: inline-block; font-size: 13px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--brand); border: 1px solid var(--border); border-radius: 999px; padding: 5px 14px; margin-bottom: 22px; }
  .hero h1 { font-size: clamp(34px, 6vw, 60px); line-height: 1.05; margin: 0 0 18px; letter-spacing: -0.02em; background: linear-gradient(120deg, var(--brand), var(--brand2)); -webkit-background-clip: text; background-clip: text; color: transparent; }
  .hero p.sub { font-size: clamp(17px, 2.4vw, 21px); color: var(--muted); max-width: 680px; margin: 0 auto 32px; }
  .cta { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; }
  .btn { display: inline-block; padding: 12px 22px; border-radius: 10px; font-weight: 600; font-size: 15px; border: 1px solid var(--border); }
  .btn.primary { background: linear-gradient(135deg, var(--brand), var(--brand2)); color: #fff; border: none; }
  .btn.ghost { background: transparent; color: var(--text); }

  .codeblock { background: var(--code-bg); border: 1px solid var(--border); border-radius: var(--radius); padding: 20px; text-align: left; font-size: 13.5px; overflow-x: auto; margin: 40px auto 0; max-width: 720px; }
  .codeblock pre { margin: 0; font-family: "SF Mono", ui-monospace, Menlo, Consolas, monospace; }

  section { padding: 56px 0; border-top: 1px solid var(--border); }
  section h2 { font-size: clamp(24px, 3.5vw, 34px); letter-spacing: -0.01em; margin: 0 0 8px; text-align: center; }
  section .lede { color: var(--muted); text-align: center; max-width: 640px; margin: 0 auto 36px; }
  .hero { border-top: none; }

  .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 18px; }
  .card { background: var(--panel); border: 1px solid var(--border); border-radius: var(--radius); padding: 22px; }
  .card .ico { font-size: 22px; margin-bottom: 10px; }
  .card h3 { margin: 0 0 6px; font-size: 17px; }
  .card p { margin: 0; color: var(--muted); font-size: 14.5px; }

  .demo { width: 100%; height: 600px; border: 1px solid var(--border); border-radius: var(--radius); }
  .demo.placeholder { display: flex; align-items: center; justify-content: center; color: var(--muted); background: var(--panel); border-style: dashed; }

  table.compare { width: 100%; border-collapse: collapse; font-size: 14.5px; }
  table.compare th, table.compare td { text-align: left; padding: 12px 14px; border-bottom: 1px solid var(--border); }
  table.compare th { color: var(--muted); font-weight: 600; }
  table.compare td:first-child { font-weight: 600; }

  .sponsor { text-align: center; }
  .tiers { display: grid; grid-template-columns: repeat(auto-fit, minmax(170px, 1fr)); gap: 16px; margin: 28px 0; }
  .tier { background: var(--panel); border: 1px solid var(--border); border-radius: var(--radius); padding: 20px; }
  .tier .amt { font-size: 26px; font-weight: 700; }
  .tier .name { color: var(--muted); font-size: 13px; text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 8px; }
  .tier p { font-size: 13px; color: var(--muted); margin: 8px 0 0; }
  .note { font-size: 13px; color: var(--muted); max-width: 620px; margin: 0 auto 20px; }

  .cc-cta { text-align: center; margin-top: 18px; }
  .demo-fallback { text-align: center; font-size: 13.5px; color: var(--muted); margin-top: 10px; }
  footer { padding: 40px 0 60px; border-top: 1px solid var(--border); color: var(--muted); font-size: 14px; text-align: center; }
</style>
